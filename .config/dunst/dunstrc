# ${XDG_CONFIG_HOME}/dunst/dunstrc
# vim:ft=dosini:fenc=utf-8:

[global]
monitor=0

geometry=512x1024-2+32
transparency=20
corner_radius=0

indicate_hidden=no

frame_width=2
horizontal_padding=2
notification_height=2
padding=0
separator_height=2

frame_color="#90a959"
separator_color=foreground

sort=yes
idle_threshold=0

font=monospace 16
line_height=0
markup=full
word_wrap=yes
ignore_newline=no

format=<b>%s</b>\n%b

alignment=left
vertical_alignment=center

show_age_threshold=-1

stack_duplicates=no
hide_duplicate_count=no

show_indicators=no
icon_position=off

sticky_history=no
history_length=10000

always_run_script=no
ignore_dbusclose=no
force_xinerama=no

mouse_left_click=close_current
mouse_middle_click=none
mouse_right_click=none

[experimental]
per_monitor_dpi=no

[urgency_low]
background="#151515"
foreground="#90a959"
timeout=15

[urgency_normal]
background="#151515"
foreground="#90a959"
timeout=15

[urgency_critical]
background="#151515"
foreground="#90a959"
frame_color="#f4bf75"
timeout=15
