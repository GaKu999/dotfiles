# ${XDG_CONFIG_HOME}/imv/config
# vim:ft=dosini:fenc=utf-8:

[options]
background=checks
loop_input=true
overlay_font=monospace:16
suppress_default_binds=true

[binds]
<Left>=prev
<bracketleft>=prev
<Right>=next
<bracketright>=next
gg=goto 0
<Shift+G>=goto -1

j=pan 0 -50
k=pan 0 50
h=pan 50 0
l=pan -50 0
c=center

a=zoom actual
<Up>=zoom 1
<Shift+plus>=zoom 1
i=zoom 1
<Down>=zoom -1
<minus>=zoom -1
o=zoom -1

<Shift+S>=upscaling next
s=scaling next

d=overlay
f=fullscreen
p=exec echo "${imv_current_file}"
q=quit
r=reset
x=close

<period>=next_frame
<space>=toggle_playing

t=slideshow +1
<Shift+T>=slideshow -1
