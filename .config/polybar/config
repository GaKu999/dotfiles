# ${XDG_CONFIG_HOME}/polybar/config
# vim:ft=dosini:fenc=utf-8:

[colors]
background = #cc151515
foreground = #f5f5f5

red     = #ac4142
green   = #90a959
yellow  = #f4bf75
blue    = #6a9fb5
magenta = #aa759f
cyan    = #75b5aa
gray    = #505050

[bar/default]
monitor = eDP-1

background = ${colors.background}
foreground = ${colors.foreground}

height    = 27
separator = " "
padding   = 1

line-size = 2

font-0 = sans-serif:pixelsize=14
font-1 = Symbols Nerd Font:pixelsize=14

modules-left   = workspaces
modules-center = window
modules-right  = mpd separator mails0 mails1 updates separator cpu memory disk0 battery0 separator tempzone0 tempzone1 separator wlan separator pulseaudio separator backlight separator date

cursor-click  = pointer
cursor-scroll = ns-resize

[module/separator]
type = custom/text

content            = ŌĆó
content-foreground = ${colors.gray}

[module/workspaces]
type = internal/xworkspaces

enable-scroll = false

label-active             = %name%
label-active-padding     = 1
label-active-underline   = ${colors.green}
label-occupied           = %name%
label-occupied-underline =
label-occupied-padding   = 1
label-urgent             = %name%
label-urgent-underline   = ${colors.yellow}
label-urgent-padding     = 1
label-empty              =
label-empty-underline    =

[module/window]
type = internal/xwindow

format-foreground = ${colors.green}

[module/mpd]
type = internal/mpd

format-offline            = ’Ćü ’ĆŹ
format-offline-foreground = ${colors.red}
format-paused             = ’Ćü ’üī <label-time> <icon-consume> <icon-random> <icon-repeat> <icon-single>
format-paused-foreground  = ${colors.gray}
format-playing            = ’Ćü ’üŗ <label-time> <icon-consume> <icon-random> <icon-repeat> <icon-single>
format-playing-foreground = ${colors.green}
format-stopped            = ’Ćü ’üŹ <label-time> <icon-consume> <icon-random> <icon-repeat> <icon-single>
format-stopped-foreground = ${colors.yellow}

label-time = (%elapsed%/%total%)

icon-consume = ’āä
icon-random  = ’ü┤
icon-repeat  = ’Ć×
icon-single  = ’Ć×Ōéü

toggle-on-foreground  = ${colors.green}
toggle-off-foreground = ${colors.gray}

[section/script]
type     = custom/script
interval = 60

format-foreground = ${colors.magenta}

[module/mails0]
inherit = section/script

exec   = mails new
format = ’É» <label>

[module/mails1]
inherit = section/script

exec   = mails cur
format = ’É░ <label>

[module/updates]
inherit = section/script

exec   = updates count
format = ’å│ <label>

[module/cpu]
type = internal/cpu

format            = ’āż <label>
format-foreground = ${colors.magenta}

[module/memory]
