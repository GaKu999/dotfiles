<Multi_key> <C> <N> : "\x0018" # 0018 : CANCEL
<Multi_key> <E> <M> : "\x0019" # 0019 : END OF MEDIUM
<Multi_key> <S> <B> : "\x001A" # 001A : SUBSTITUTE
