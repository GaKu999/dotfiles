<Multi_key> <H> <T> : "\x0009" # 0009 : CHARACTER TABULATION
<Multi_key> <L> <F> : "\x000A" # 000A : LINE FEED (LF)
<Multi_key> <N> <U> : "\x000A" # 000A : LINE FEED (LF)
<Multi_key> <V> <T> : "\x000B" # 000B : LINE TABULATION
<Multi_key> <F> <F> : "\x000C" # 000C : FORM FEED (FF)
