# ${XDG_CONFIG_HOME}/X11/compose.d/control
# vim:ft=conf:fenc=utf-8:

<Multi_key> <S> <H> : "\x0001" # 0001 : START OF HEADING
<Multi_key> <S> <X> : "\x0002" # 0002 : START OF TEXT
<Multi_key> <E> <X> : "\x0003" # 0003 : END OF TEXT
<Multi_key> <E> <T> : "\x0004" # 0004 : END OF TRANSMISSION
<Multi_key> <E> <Q> : "\x0005" # 0005 : ENQUIRY
<Multi_key> <A> <K> : "\x0006" # 0006 : ACKNOWLEDGE
